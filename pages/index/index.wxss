.container {
  padding: 32rpx;
  min-height: 100vh;
  background-color: #FFFFFF;
}

.dark-mode.container {
  background-color: #1A1A2E;
}

.header {
  text-align: center;
  padding: 40rpx 0;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1A1A2E;
}

.dark-mode .title {
  color: #FFFFFF;
}

.section-title {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 20rpx;
  display: block;
}

.dark-mode .section-title {
  color: #B0B0B0;
}

.last-plan {
  margin-bottom: 40rpx;
}

.last-plan-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #F8F8F8;
  border-radius: 16rpx;
  padding: 24rpx;
}

.dark-mode .last-plan-card {
  background-color: #16213E;
}

.plan-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
  display: block;
}

.dark-mode .plan-name {
  color: #FFFFFF;
}

.plan-desc {
  font-size: 24rpx;
  color: #666666;
  margin-top: 8rpx;
  display: block;
}

.dark-mode .plan-desc {
  color: #B0B0B0;
}

.start-btn {
  background-color: #E94560;
  color: #FFFFFF;
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.presets {
  margin-bottom: 40rpx;
}

.preset-grid {
  display: flex;
  gap: 24rpx;
}

.preset-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #F8F8F8;
  border-radius: 16rpx;
  padding: 32rpx 16rpx;
}

.dark-mode .preset-item {
  background-color: #16213E;
}

.preset-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.preset-name {
  font-size: 28rpx;
  color: #1A1A2E;
  font-weight: 500;
}

.dark-mode .preset-name {
  color: #FFFFFF;
}

.quick-start {
  margin-top: 60rpx;
}

.btn-primary {
  width: 100%;
  background-color: #E94560;
  color: #FFFFFF;
  border: none;
  border-radius: 16rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 600;
}
