.container {
  height: 100vh;
  background-color: #FFFFFF;
  display: flex;
  flex-direction: column;
}

.dark-mode.container {
  background-color: #1A1A2E;
}

.content {
  flex: 1;
  padding: 32rpx;
  box-sizing: border-box;
}

.form-item {
  margin-bottom: 40rpx;
}

.form-label {
  font-size: 28rpx;
  color: #1A1A2E;
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
}

.dark-mode .form-label {
  color: #FFFFFF;
}

.form-input {
  width: 100%;
  padding: 24rpx;
  border: 2rpx solid #E5E5E5;
  border-radius: 12rpx;
  font-size: 32rpx;
  background-color: #FFFFFF;
  color: #1A1A2E;
  box-sizing: border-box;
}

.dark-mode .form-input {
  background-color: #16213E;
  border-color: #333333;
  color: #FFFFFF;
}

.form-input::placeholder {
  color: #999999;
}

.dark-mode .form-input::placeholder {
  color: #666666;
}

.type-selector {
  display: flex;
  gap: 16rpx;
}

.type-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  border: 2rpx solid #E5E5E5;
  border-radius: 12rpx;
  background-color: #FFFFFF;
}

.dark-mode .type-item {
  background-color: #16213E;
  border-color: #333333;
}

.type-item.active {
  border-color: #E94560;
  background-color: #FFF5F7;
}

.dark-mode .type-item.active {
  background-color: #2D1F3D;
}

.type-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.type-name {
  font-size: 26rpx;
  color: #1A1A2E;
}

.dark-mode .type-name {
  color: #FFFFFF;
}

.form-section {
  margin-bottom: 40rpx;
}

.config-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.config-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: #F8F8F8;
  border-radius: 12rpx;
}

.dark-mode .config-item {
  background-color: #16213E;
}

.config-label {
  font-size: 28rpx;
  color: #333333;
  flex: 1;
}

.dark-mode .config-label {
  color: #FFFFFF;
}

.stepper {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.stepper-btn {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  font-size: 36rpx;
  color: #E94560;
  background-color: #FFF5F7;
  border-radius: 50%;
}

.dark-mode .stepper-btn {
  background-color: #2D1F3D;
}

.stepper-btn.small {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  font-size: 28rpx;
}

.stepper-input {
  width: 100rpx;
  height: 64rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
  background-color: #FFFFFF;
  border: 2rpx solid #E5E5E5;
  border-radius: 8rpx;
}

.dark-mode .stepper-input {
  background-color: #16213E;
  border-color: #333333;
  color: #FFFFFF;
}

.stepper-input.small {
  width: 80rpx;
  height: 48rpx;
  font-size: 28rpx;
}

.beat-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.beat-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: #F8F8F8;
  border-radius: 12rpx;
}

.dark-mode .beat-item {
  background-color: #16213E;
}

.beat-label {
  font-size: 28rpx;
  color: #333333;
}

.dark-mode .beat-label {
  color: #FFFFFF;
}

.beat-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.btn-small {
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  background-color: #F5F5F5;
  color: #1A1A2E;
  border: none;
  border-radius: 8rpx;
}

.dark-mode .btn-small {
  background-color: #16213E;
  color: #FFFFFF;
}

.btn-small.btn-danger {
  background-color: #FFF0F0;
  color: #E94560;
}

.dark-mode .btn-small.btn-danger {
  background-color: #2D1F3D;
}

.switch-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 20rpx;
  background-color: #F8F8F8;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.dark-mode .switch-item {
  background-color: #16213E;
}

.switch-label {
  font-size: 28rpx;
  color: #333333;
}

.dark-mode .switch-label {
  color: #FFFFFF;
}

.save-btn-wrap {
  padding: 24rpx 32rpx;
  background-color: #FFFFFF;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.dark-mode .save-btn-wrap {
  background-color: #1A1A2E;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.3);
}

.btn-primary {
  width: 100%;
  background-color: #E94560;
  color: #FFFFFF;
  border: none;
  border-radius: 16rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 600;
}
