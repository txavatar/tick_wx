.container {
  padding: 32rpx;
  min-height: 100vh;
  background-color: #FFFFFF;
}

.form-item {
  margin-bottom: 40rpx;
}

.form-label {
  font-size: 28rpx;
  color: #1A1A2E;
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  padding: 24rpx;
  border: 2rpx solid #E5E5E5;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.type-selector {
  display: flex;
  gap: 16rpx;
}

.type-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  border: 2rpx solid #E5E5E5;
  border-radius: 12rpx;
  background-color: #FFFFFF;
}

.type-item.active {
  border-color: #E94560;
  background-color: #FFF5F7;
}

.type-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.type-name {
  font-size: 26rpx;
  color: #1A1A2E;
}

.form-section {
  margin-bottom: 40rpx;
}

.config-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.config-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.config-label {
  font-size: 28rpx;
  color: #333333;
}

.stepper {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.stepper-btn {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 36rpx;
  color: #E94560;
  background-color: #FFF5F7;
  border-radius: 50%;
}

.stepper-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
  min-width: 80rpx;
  text-align: center;
}

.beat-list {
  margin-bottom: 20rpx;
}

.beat-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.beat-label {
  font-size: 28rpx;
  color: #333333;
}

.beat-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.btn-small {
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  background-color: #F5F5F5;
  color: #1A1A2E;
  border: none;
  border-radius: 8rpx;
}

.btn-small.btn-danger {
  background-color: #FFF0F0;
  color: #E94560;
}

.switch-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.switch-label {
  font-size: 28rpx;
  color: #333333;
}

.save-btn-wrap {
  margin-top: 60rpx;
}

.btn-primary {
  width: 100%;
  background-color: #E94560;
  color: #FFFFFF;
  border: none;
  border-radius: 16rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 600;
}
