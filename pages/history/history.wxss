.container {
  padding: 32rpx;
  min-height: 100vh;
  background-color: #FFFFFF;
}

.stats {
  display: flex;
  gap: 32rpx;
  margin-bottom: 40rpx;
}

.stat-item {
  flex: 1;
  background-color: #F8F8F8;
  border-radius: 16rpx;
  padding: 32rpx;
  text-align: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #E94560;
  display: block;
}

.stat-label {
  font-size: 26rpx;
  color: #666666;
  margin-top: 8rpx;
  display: block;
}

.date-group {
  margin-bottom: 32rpx;
}

.date-header {
  font-size: 26rpx;
  color: #999999;
  display: block;
  margin-bottom: 16rpx;
}

.history-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #F8F8F8;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.history-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A2E;
  display: block;
  margin-bottom: 8rpx;
}

.history-detail {
  font-size: 24rpx;
  color: #666666;
}

.history-status {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.history-status.completed {
  background-color: #E8F5E9;
  color: #4CAF50;
}

.history-status.stopped {
  background-color: #FFF3E0;
  color: #FF9800;
}

.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-text {
  font-size: 32rpx;
  color: #1A1A2E;
  display: block;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #666666;
}
