.container {
  height: 100vh;
  background-color: #1A1A2E;
  display: flex;
  flex-direction: column;
  padding: 60rpx 32rpx;
  box-sizing: border-box;
}

.top-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.phase-indicator {
  margin-bottom: 30rpx;
}

.phase-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #B0B0B0;
  text-transform: uppercase;
  letter-spacing: 4rpx;
}

.phase-text.work {
  color: #E94560;
}

.phase-text.rest {
  color: #4CAF50;
}

.phase-text.prep {
  color: #FF9800;
}

.phase-text.completed {
  color: #4CAF50;
}

.timer-display {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 40rpx;
}

.time-value {
  font-size: 160rpx;
  font-weight: 700;
  color: #FFFFFF;
  font-variant-numeric: tabular-nums;
}

.time-unit {
  font-size: 32rpx;
  color: #B0B0B0;
  margin-left: 8rpx;
}

.progress-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.set-info {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.eta-info {
  font-size: 26rpx;
  color: #B0B0B0;
}

.progress-bar {
  width: 100%;
}

.progress-track {
  height: 8rpx;
  background-color: #333333;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background-color: #E94560;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.bottom-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 60rpx;
}

.control-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background-color: #E94560;
}

.control-btn.pause {
  background-color: #FF9800;
}

.control-text {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.hint-text {
  font-size: 24rpx;
  color: #666666;
  margin-top: 24rpx;
  height: 40rpx;
  line-height: 40rpx;
}

.stop-btn-placeholder {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
}

.stop-btn {
  display: flex;
  align-items: center;
  justify-content: center;
}

.stop-text {
  font-size: 28rpx;
  color: #B0B0B0;
}
