.container {
  padding: 32rpx;
  min-height: 100vh;
  background-color: #FFFFFF;
}

.filter-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.tab {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #666666;
  background-color: #F5F5F5;
}

.tab.active {
  background-color: #E94560;
  color: #FFFFFF;
}

.plan-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.plan-card {
  background-color: #F8F8F8;
  border-radius: 16rpx;
  padding: 24rpx;
}

.plan-main {
  margin-bottom: 16rpx;
}

.plan-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.plan-type-icon {
  font-size: 32rpx;
}

.plan-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.plan-desc {
  font-size: 26rpx;
  color: #666666;
}

.plan-actions {
  display: flex;
  gap: 24rpx;
  border-top: 1rpx solid #E5E5E5;
  padding-top: 16rpx;
}

.action-btn {
  font-size: 26rpx;
  color: #1A1A2E;
}

.action-btn.delete {
  color: #E94560;
}

.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-text {
  font-size: 32rpx;
  color: #1A1A2E;
  display: block;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #666666;
}

.create-btn-wrap {
  margin-top: 40rpx;
}

.btn-primary {
  width: 100%;
  background-color: #E94560;
  color: #FFFFFF;
  border: none;
  border-radius: 16rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 600;
}
