page {
  --primary-color: #1A1A2E;
  --secondary-color: #16213E;
  --accent-color: #E94560;
  --success-color: #4CAF50;
  --warning-color: #FF9800;
  --bg-color: #FFFFFF;
  --text-color: #333333;
  --text-secondary: #666666;
  --border-color: #E5E5E5;
  --card-bg: #F8F8F8;
}

page {
  background-color: var(--bg-color);
  color: var(--text-color);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.dark-mode, page.dark-mode {
  --bg-color: #1A1A2E;
  --text-color: #FFFFFF;
  --text-secondary: #B0B0B0;
  --border-color: #333333;
  --card-bg: #16213E;
}

.dark-mode page, page.dark-mode {
  background-color: var(--bg-color);
  color: var(--text-color);
}

.container {
  min-height: 100vh;
  padding: 32rpx;
}

.dark-mode .container {
  background-color: var(--bg-color);
}

/* 通用卡片 */
.card {
  background-color: var(--card-bg);
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 通用按钮 */
.btn-primary {
  background-color: var(--accent-color);
  color: #FFFFFF;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-secondary {
  background-color: var(--primary-color);
  color: #FFFFFF;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 600;
}

/* 通用表单 */
.form-input {
  width: 100%;
  padding: 24rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 12rpx;
  font-size: 30rpx;
  background-color: var(--bg-color);
  color: var(--text-color);
}

.form-label {
  font-size: 28rpx;
  color: var(--text-color);
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
}

/* 通用设置项 */
.settings-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 24rpx;
  border-bottom: 1rpx solid var(--border-color);
  background-color: var(--card-bg);
}

.dark-mode .settings-item:last-child {
  border-bottom: none;
}

/* Tab Bar */
.dark-mode .tab-bar {
  background-color: var(--secondary-color);
  border-top-color: var(--border-color);
}
